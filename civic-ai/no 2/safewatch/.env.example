# =============================================================
# SafeWatch — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Telegram Bot Configuration
# Create a bot via @BotFather on Telegram to get the token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat IDs for alert agents
# Use @userinfobot or @RawDataBot to get your chat ID
TELEGRAM_CHAT_ID_MAIN=your_main_agent_chat_id
TELEGRAM_CHAT_ID_PARKING=your_parking_agent_chat_id
