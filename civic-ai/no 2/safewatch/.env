# SafeWatch Environment Configuration
# Rename this file to .env and fill in the values

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Camera Configuration
# Use 0 for default webcam, or RTSP URL for network cameras
CAMERA_0_URL=0
CAMERA_1_URL=rtsp://user:pass@ip:port/stream

# System Settings
LOG_LEVEL=INFO
MODEL_PATH=models/yolov8n.pt
POSE_MODEL_PATH=models/pose_landmarker.task

# Dashboard Settings
STREAMLIT_SERVER_PORT=8501
DASHBOARD_REFRESH_RATE=2
